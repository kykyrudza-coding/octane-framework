{
    "name": "octane/framework",
    "description": "A modern PHP framework focused on performance, developer experience, and clean architecture.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "framework",
        "php",
        "octane",
        "horizon"
    ],
    "require": {
        "php": "^8.4",
        "symfony/error-handler": "^8.1",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.0",
        "laravel/pint": "v1.29.1",
        "symfony/var-dumper": "v7.4.8",
        "phpstan/phpstan": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Horizon\\": "src/Horizon/"
        },
        "files": [
            "src/Horizon/Arch/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "phpstan": [
            "./vendor/bin/phpstan analyse --no-progress"
        ],
        "pint": [
            "./vendor/bin/pint"
        ],
        "test": [
            "./vendor/bin/phpunit --testdox"
        ],
        "check": [
            "./vendor/bin/phpstan analyse --no-progress",
            "./vendor/bin/phpunit --testdox",
            "./vendor/bin/pint --test"
        ]
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
